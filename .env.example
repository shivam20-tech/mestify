# Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=5000

# Redis (Upstash recommended for production)
# Get free instance at: https://upstash.com
# Leave blank to use in-memory cache (fine for single-instance Railway)
REDIS_URL=

# yt-dlp binary path
# Railway/Linux: /usr/local/bin/yt-dlp
# Windows (local dev): C:/path/to/yt-dlp.exe
YTDLP_PATH=/usr/local/bin/yt-dlp

# Audio file cache settings
AUDIO_CACHE_MAX=100
STREAM_URL_TTL_SEC=21600

# Max concurrent yt-dlp extractions (prevents OOM)
PREFETCH_CONCURRENCY=4

# CORS — comma-separated origins, or * for all
ALLOWED_ORIGINS=*
