{
  "name": "mestify-backend",
  "version": "1.0.0",
  "description": "Mestify Music Streaming - Backend API",
  "main": "server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "check": "node -e \"const fs=require('fs'); for (const f of ['server.js','public/script.js','public/sw.js']) { new Function(fs.readFileSync(f,'utf8')); console.log('ok '+f); }\"",
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "youtubei.js": "^17.0.1",
    "ytmusic-api": "^5.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
